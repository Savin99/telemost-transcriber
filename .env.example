# ============================================
# telemost-transcriber — переменные окружения
# ============================================
# Скопируй в .env и заполни значения.
# Переменные с пустыми значениями — обязательные.
# Переменные с дефолтами — опциональные, раскомментируй для изменения.

# ------ Обязательные ------

# Telegram-бот
TG_BOT_TOKEN=

# API-ключ для bot-service (общий секрет между tg-bot и bot-service)
TELEMOST_SERVICE_API_KEY=

# HuggingFace токен (для pyannote-моделей диаризации)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx

# ------ Bot-service (FastAPI, порт 8000) ------

# BOT_NAME=Транскрибатор
# TRANSCRIBER_URL=http://localhost:8001
# DATABASE_URL=sqlite+aiosqlite:///transcriber.db
# RECORDINGS_DIR=/app/recordings
# Автоматически заливать оригинальный wav в Google Drive (папка Originals/)
# после успешной транскрибации — чтобы оригинал не терялся при rebuild хоста.
# UPLOAD_ORIGINAL_RECORDING=true

# ------ Transcriber-service (FastAPI, порт 8001) ------

# Язык распознавания (пустая строка или auto = авто-определение)
# ASR_LANGUAGE=ru

# Диаризация (разделение спикеров)
# DIARIZATION_MODEL=pyannote/speaker-diarization-community-1
# CLUSTERING_THRESHOLD=0.35
# VOICE_BANK_DIR=/app/voice_bank
# VOICE_MATCH_THRESHOLD=0.40
# Порог для auto-merge кластеров после разметки (0.40 слишком низкий — ложно
# склеивает разных людей с похожими голосами, напр. двух мужчин similar timbre).
# AUTO_MERGE_THRESHOLD=0.80
# Per-segment voting: доля сегментов кластера, голосующих за одного voice_bank
# speaker'а, чтобы поднять кластер из Unknown в known.
# SEGMENT_VOTE_FRACTION=0.60
# SEGMENT_VOTE_MIN_COUNT=3
# MIN_EMBEDDING_SEGMENT_SEC=1.0
# Склейка коротких пауз между репликами одного спикера (сек).
# 0.0 = не склеивать; приводит к фрагментарной смене спикеров.
# MIN_DURATION_OFF=0.5
# Только для community-1 (VBx):
# CLUSTERING_FA=0.04
# CLUSTERING_FB=0.9
# Только для 3.1 (agglomerative):
# CLUSTERING_THRESHOLD=0.55
# CLUSTERING_MIN_CLUSTER_SIZE=15

# ------ LLM: Claude API ------

# Общий ключ для всех LLM-фич (speaker/transcript refinement, meeting metadata)
# ANTHROPIC_API_KEY=sk-ant-...

# Speaker LLM Refinement (уточнение имён спикеров через Claude)
# SPEAKER_LLM_REFINEMENT_ENABLED=false
# SPEAKER_LLM_EXECUTOR_MODEL=claude-sonnet-4-6
# SPEAKER_LLM_ADVISOR_MODEL=claude-opus-4-7
# SPEAKER_LLM_ADVISOR_ENABLED=true
# SPEAKER_LLM_ADVISOR_MAX_USES=2
# SPEAKER_LLM_MAX_TOKENS=4096
# SPEAKER_LLM_TIMEOUT_SEC=120
# SPEAKER_LLM_MAX_CHANGES=80

# Transcript LLM Refinement (улучшение текста транскрипта через Claude)
# TRANSCRIPT_LLM_REFINEMENT_ENABLED=false
# TRANSCRIPT_LLM_EXECUTOR_MODEL=claude-sonnet-4-6
# TRANSCRIPT_LLM_ADVISOR_MODEL=claude-opus-4-7
# TRANSCRIPT_LLM_ADVISOR_ENABLED=true
# TRANSCRIPT_LLM_ADVISOR_MAX_USES=2
# TRANSCRIPT_LLM_MAX_TOKENS=4096
# TRANSCRIPT_LLM_TIMEOUT_SEC=120
# TRANSCRIPT_LLM_MAX_CHANGES=120

# Meeting Metadata (генерация названий файлов/папок через Claude)
# MEETING_METADATA_LLM_ENABLED=false
# MEETING_METADATA_EXECUTOR_MODEL=claude-sonnet-4-6
# MEETING_METADATA_ADVISOR_MODEL=claude-opus-4-7
# MEETING_METADATA_ADVISOR_ENABLED=true
# MEETING_METADATA_ADVISOR_MAX_USES=2
# MEETING_METADATA_TIMEOUT_SEC=120
# MEETING_METADATA_MAX_TOKENS=1024
# MEETING_METADATA_RULES_JSON=
# MEETING_METADATA_RULES_PATH=

# ------ Google Drive — сохранение транскриптов ------

# GDRIVE_FOLDER_ID=
# GDRIVE_CLIENT_SECRET=/app/credentials/client_secret.json
# GDRIVE_TOKEN_PATH=/app/credentials/gdrive_token.json

# ------ Drive Watcher (авто-транскрибация файлов из Drive) ------

# DRIVE_POLL_INTERVAL=30
# DRIVE_WORK_DIR=/tmp/drive_watcher
# DRIVE_ARCHIVE_DIR=/workspace/recordings/drive_imports

# ------ Telegram-бот (дополнительные) ------

# BOT_API_URL=http://localhost:8000
# BOT_API_KEY=               # если отличается от TELEMOST_SERVICE_API_KEY
# POLL_INTERVAL=10
# VOICE_REVIEW_SAMPLE_COUNT=2
# VOICE_REVIEW_SAMPLE_MAX_SECONDS=10

# ------ Postgres (только для docker-compose) ------

# POSTGRES_USER=user
# POSTGRES_PASSWORD=pass
# POSTGRES_DB=telemost_bot
