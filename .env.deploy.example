# deploy_vds.sh: настройки подключения к продакшн-VDS.
# Скопируй в .env.deploy (он в .gitignore).

# Основное подключение к VDS (193.233.87.211).
VDS_SSH_HOST="193.233.87.211"
VDS_SSH_PORT="22"
VDS_SSH_USER="root"

# Опционально: явная SSH-команда — для алиасов ~/.ssh/config или ProxyJump.
# Если пусто — скрипт собирает "ssh -p $VDS_SSH_PORT $VDS_SSH_USER@$VDS_SSH_HOST"
# автоматически. Оставляй пустым, если нет особых требований.
VDS_SSH=""

# Modal-токены (нужны только для `./deploy_vds.sh modal`).
# Альтернатива — один раз выполнить локально `modal token new` (токены
# сохранятся в ~/.modal.toml, тогда строки ниже можно закомментировать).
#MODAL_TOKEN_ID="ak-..."
#MODAL_TOKEN_SECRET="as-..."
